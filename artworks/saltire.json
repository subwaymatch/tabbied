{
  "name": "Saltire",
  "slug": "saltire",
  "galleryOrder": 346,
  "galleryWhite": true,
  "description": "Diagonal X saltires crossing the grid, the strokes re-colouring on each seed.",
  "palette": [
    "#0B2540",
    "#1B4075",
    "#3E8BFF",
    "#3EECFF",
    "#9EFFD8",
    "#ECFFEC"
  ],
  "colors": {
    "min": 2,
    "max": 6,
    "default": 6
  },
  "options": [
    {
      "id": "grid",
      "displayName": "Columns and rows",
      "type": "ButtonSelectGroup",
      "default": "8x12",
      "options": [
        "2x3",
        "4x6",
        "6x9",
        "8x12",
        "10x15"
      ],
      "replace": "${grid}"
    },
    {
      "id": "frequency",
      "displayName": "Frequency",
      "type": "Slider",
      "default": 1,
      "min": 0.2,
      "max": 1,
      "step": 0.1,
      "replace": "${shapeFrequency}"
    }
  ],
  "code": {
    "style": "--rule: ( @random(${shapeFrequency}) { background: @p(var(--color1), var(--color2), var(--color3), var(--color4), var(--color5)); -webkit-clip-path: polygon(0 18%, 18% 0, 50% 32%, 82% 0, 100% 18%, 68% 50%, 100% 82%, 82% 100%, 50% 68%, 18% 100%, 0 82%, 32% 50%); clip-path: polygon(0 18%, 18% 0, 50% 32%, 82% 0, 100% 18%, 68% 50%, 100% 82%, 82% 100%, 50% 68%, 18% 100%, 0 82%, 32% 50%); } -webkit-transition: ease 450ms; transition: ease 450ms; );",
    "doodle": ":doodle { @grid: ${grid}; @size: ${width} ${height}; overflow:hidden; text-align:center; box-sizing:border-box } :container { background: var(--color0); overflow:hidden; }"
  }
}
