{
  "name": "Pinion",
  "slug": "pinion",
  "galleryOrder": 354,
  "galleryWhite": true,
  "description": "Cogged squares with notched corners meshing across the grid, re-tinting on reseed.",
  "palette": [
    "#0F2027",
    "#3FFFB2",
    "#3EECFF",
    "#2BB3A3",
    "#D89FFF",
    "#E9FFF9"
  ],
  "colors": {
    "min": 2,
    "max": 6,
    "default": 6
  },
  "options": [
    {
      "id": "grid",
      "displayName": "Columns and rows",
      "type": "ButtonSelectGroup",
      "default": "8x12",
      "options": [
        "2x3",
        "4x6",
        "6x9",
        "8x12",
        "10x15"
      ],
      "replace": "${grid}"
    },
    {
      "id": "frequency",
      "displayName": "Frequency",
      "type": "Slider",
      "default": 1,
      "min": 0.2,
      "max": 1,
      "step": 0.1,
      "replace": "${shapeFrequency}"
    }
  ],
  "code": {
    "style": "--rule: ( @random(${shapeFrequency}) { background: @p(var(--color1), var(--color2), var(--color3), var(--color4), var(--color5)); -webkit-clip-path: polygon(20% 0, 40% 12%, 60% 12%, 80% 0, 88% 20%, 100% 40%, 100% 60%, 88% 80%, 80% 100%, 60% 88%, 40% 88%, 20% 100%, 12% 80%, 0 60%, 0 40%, 12% 20%); clip-path: polygon(20% 0, 40% 12%, 60% 12%, 80% 0, 88% 20%, 100% 40%, 100% 60%, 88% 80%, 80% 100%, 60% 88%, 40% 88%, 20% 100%, 12% 80%, 0 60%, 0 40%, 12% 20%); } -webkit-transition: ease 450ms; transition: ease 450ms; );",
    "doodle": ":doodle { @grid: ${grid}; @size: ${width} ${height}; overflow:hidden; text-align:center; box-sizing:border-box } :container { background: var(--color0); overflow:hidden; }"
  }
}
