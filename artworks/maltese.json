{
  "name": "Maltese",
  "slug": "maltese",
  "galleryOrder": 349,
  "galleryWhite": true,
  "description": "Maltese crosses with flared arms, re-shading on every redraw.",
  "palette": [
    "#141233",
    "#6C4AB6",
    "#3EECFF",
    "#FF3D8B",
    "#F5DD32",
    "#3FFFB2"
  ],
  "colors": {
    "min": 2,
    "max": 6,
    "default": 6
  },
  "options": [
    {
      "id": "grid",
      "displayName": "Columns and rows",
      "type": "ButtonSelectGroup",
      "default": "8x12",
      "options": [
        "2x3",
        "4x6",
        "6x9",
        "8x12",
        "10x15"
      ],
      "replace": "${grid}"
    },
    {
      "id": "frequency",
      "displayName": "Frequency",
      "type": "Slider",
      "default": 1,
      "min": 0.2,
      "max": 1,
      "step": 0.1,
      "replace": "${shapeFrequency}"
    }
  ],
  "code": {
    "style": "--rule: ( @random(${shapeFrequency}) { background: @p(var(--color1), var(--color2), var(--color3), var(--color4), var(--color5)); -webkit-clip-path: polygon(50% 50%, 22% 0, 78% 0, 50% 50%, 100% 22%, 100% 78%, 50% 50%, 78% 100%, 22% 100%, 50% 50%, 0 78%, 0 22%); clip-path: polygon(50% 50%, 22% 0, 78% 0, 50% 50%, 100% 22%, 100% 78%, 50% 50%, 78% 100%, 22% 100%, 50% 50%, 0 78%, 0 22%); } -webkit-transition: ease 450ms; transition: ease 450ms; );",
    "doodle": ":doodle { @grid: ${grid}; @size: ${width} ${height}; overflow:hidden; text-align:center; box-sizing:border-box } :container { background: var(--color0); overflow:hidden; }"
  }
}
