{
  "name": "Crux",
  "slug": "crux",
  "galleryOrder": 501,
  "description": "Plus-signs fattening and thinning their arms on every redraw.",
  "palette": [
    "#FAF7F0",
    "#232529",
    "#E63329",
    "#1D3D8F",
    "#F0C02E",
    "#3EECFF"
  ],
  "colors": {
    "min": 2,
    "max": 6,
    "default": 6
  },
  "options": [
    {
      "id": "grid",
      "displayName": "Columns and rows",
      "type": "ButtonSelectGroup",
      "default": "6x9",
      "options": [
        "2x3",
        "4x6",
        "6x9",
        "8x12",
        "10x15"
      ],
      "replace": "${grid}"
    },
    {
      "id": "frequency",
      "displayName": "Frequency",
      "type": "Slider",
      "default": 1,
      "min": 0.2,
      "max": 1,
      "step": 0.1,
      "replace": "${shapeFrequency}"
    }
  ],
  "code": {
    "style": "--rule: ( @random(${shapeFrequency}) { background: @p(var(--color1), var(--color2), var(--color3), var(--color4), var(--color5)); -webkit-clip-path: @pick(polygon(36% 0, 64% 0, 64% 36%, 100% 36%, 100% 64%, 64% 64%, 64% 100%, 36% 100%, 36% 64%, 0 64%, 0 36%, 36% 36%), polygon(43% 0, 57% 0, 57% 43%, 100% 43%, 100% 57%, 57% 57%, 57% 100%, 43% 100%, 43% 57%, 0 57%, 0 43%, 43% 43%)); clip-path: @pick(polygon(36% 0, 64% 0, 64% 36%, 100% 36%, 100% 64%, 64% 64%, 64% 100%, 36% 100%, 36% 64%, 0 64%, 0 36%, 36% 36%), polygon(43% 0, 57% 0, 57% 43%, 100% 43%, 100% 57%, 57% 57%, 57% 100%, 43% 100%, 43% 57%, 0 57%, 0 43%, 43% 43%)); } -webkit-transition: ease 450ms; transition: ease 450ms; );",
    "doodle": ":doodle { @grid: ${grid}; @size: ${width} ${height}; overflow:hidden; text-align:center; box-sizing:border-box } :container { background: var(--color0); overflow:hidden; }"
  }
}
