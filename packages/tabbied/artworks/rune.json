{
  "name": "Rune",
  "slug": "rune",
  "galleryOrder": 599,
  "description": "Angular runes re-carving themselves into new glyphs on every redraw.",
  "palette": [
    "#FFF4E6",
    "#3D348B",
    "#7678ED",
    "#F7B801",
    "#F18701",
    "#F35B04"
  ],
  "colors": {
    "min": 2,
    "max": 6,
    "default": 6
  },
  "options": [
    {
      "id": "grid",
      "displayName": "Columns and rows",
      "type": "ButtonSelectGroup",
      "default": "6x9",
      "options": [
        "2x3",
        "4x6",
        "6x9",
        "8x12",
        "10x15"
      ],
      "replace": "${grid}"
    },
    {
      "id": "frequency",
      "displayName": "Frequency",
      "type": "Slider",
      "default": 1,
      "min": 0.2,
      "max": 1,
      "step": 0.1,
      "replace": "${shapeFrequency}"
    }
  ],
  "code": {
    "style": "--rule: ( --rot: @pick(0deg, 90deg, 180deg, 270deg); @random(${shapeFrequency}) { background: @p(var(--color1), var(--color2), var(--color3), var(--color4), var(--color5)); -webkit-clip-path: @pick(polygon(20% 10%, 32% 10%, 32% 48%, 70% 48%, 70% 90%, 58% 90%, 58% 60%, 20% 60%), polygon(20% 10%, 80% 10%, 80% 22%, 50% 22%, 50% 90%, 38% 90%, 38% 22%, 20% 22%), polygon(12% 18%, 88% 18%, 88% 30%, 56% 30%, 84% 82%, 72% 88%, 46% 36%, 46% 82%, 34% 82%, 34% 28%, 12% 28%)); clip-path: @pick(polygon(20% 10%, 32% 10%, 32% 48%, 70% 48%, 70% 90%, 58% 90%, 58% 60%, 20% 60%), polygon(20% 10%, 80% 10%, 80% 22%, 50% 22%, 50% 90%, 38% 90%, 38% 22%, 20% 22%), polygon(12% 18%, 88% 18%, 88% 30%, 56% 30%, 84% 82%, 72% 88%, 46% 36%, 46% 82%, 34% 82%, 34% 28%, 12% 28%)); -webkit-transform: rotate(@var(--rot)); transform: rotate(@var(--rot)); } -webkit-transition: ease 450ms; transition: ease 450ms; );",
    "doodle": ":doodle { @grid: ${grid}; @size: ${width} ${height}; overflow:hidden; text-align:center; box-sizing:border-box } :container { background: var(--color0); overflow:hidden; }"
  }
}
