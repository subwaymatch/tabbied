{
  "name": "tabbied",
  "version": "0.1.0",
  "description": "Tabbied generative artworks: a framework-agnostic core plus a React component, powered by css-doodle.",
  "type": "module",
  "license": "MIT",
  "author": "Sy Hong and Ye Joo Park",
  "homepage": "https://tabbied.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/subwaymatch/tabbied.git",
    "directory": "packages/tabbied"
  },
  "keywords": [
    "css-doodle",
    "generative",
    "generative-art",
    "art",
    "pattern",
    "svg",
    "react"
  ],
  "exports": {
    ".": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    },
    "./artworks": {
      "types": "./dist/artworks.generated.d.ts",
      "import": "./dist/artworks.generated.js"
    }
  },
  "files": [
    "dist",
    "artworks"
  ],
  "sideEffects": [
    "./dist/**/register.js"
  ],
  "scripts": {
    "codegen": "node scripts/codegen.mjs",
    "build": "node scripts/codegen.mjs && node -e \"fs.rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.json",
    "dev": "node scripts/codegen.mjs && tsc -p tsconfig.json --watch",
    "typecheck": "node scripts/codegen.mjs && tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "css-doodle": "^0.51.0"
  },
  "peerDependencies": {
    "react": ">=18 <20"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=18"
  }
}
